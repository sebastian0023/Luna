# Cloudflare Worker Configuration
ENVIRONMENT=development

# MongoDB (para Data API o conexión directa)
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/luna?appName=Api
MONGO_DATA_API_KEY=your_mongodb_data_api_key

# API Keys y configuración adicional
API_KEY=your_api_key_here
SECRET_TOKEN=your_secret_token_here
